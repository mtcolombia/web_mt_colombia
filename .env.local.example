# ─── Admin CMS ──────────────────────────────────────────────────────────────
# Credenciales del único usuario administrador
ADMIN_USERNAME=admin
ADMIN_PASSWORD=cambia-esta-contrasena

# Secreto para iron-session (mínimo 32 caracteres, aleatorio)
# Genera uno con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=cambia-este-secreto-por-uno-aleatorio-de-32-caracteres

# ─── GitHub API (CMS backend) ────────────────────────────────────────────────
# Token personal con permiso "Contents: Read and write" sobre este repo
# Crear en: https://github.com/settings/tokens → Fine-grained personal access tokens
GITHUB_TOKEN=github_pat_xxxxx
GITHUB_OWNER=tu-usuario-github
GITHUB_REPO=web-centro-mt
GITHUB_BRANCH=main

# ─── Email (opcional) ────────────────────────────────────────────────────────
# Descomenta y configura para enviar emails con Resend
# RESEND_API_KEY=re_xxxxx
